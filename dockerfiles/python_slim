FROM --platform=i386 i386/python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends bash zsh coreutils mg doas tmux && \
    rm -rf /var/lib/apt/lists/* && \
    groupadd -r user && \
    useradd -g user -s /bin/bash -m user && \
    echo "user:password" | chpasswd && \
    echo "root:password" | chpasswd && \
    mkdir -p /etc/doas.d && \
    echo "permit persist :user" > /etc/doas.d/doas.conf

WORKDIR /home/user/

COPY --chown=user:user image/home/ /home/user/
COPY image/bin/ /usr/local/bin/

ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash" EDITOR="mg" LANG="en_US.UTF-8" LC_ALL="en_US.UTF-8"

USER user
CMD [ "/bin/bash" ]
